{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowTaskAppMediaAccess",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::YOUR_BUCKET_NAME/media/*"
    },
    {
      "Sid": "AllowBucketListForMediaPrefix",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::YOUR_BUCKET_NAME",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "media/*"
          ]
        }
      }
    }
  ]
}
